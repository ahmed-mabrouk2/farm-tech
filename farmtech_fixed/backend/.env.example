# Core Django configurations
SECRET_KEY=django-insecure-prod-key-should-be-random-and-long
DEBUG=False
ALLOWED_HOSTS=your-app.onrender.com,localhost,127.0.0.1

# Database Configuration (leave empty to use default SQLite)
# For Postgres on Render/Railway: postgres://user:password@host:port/dbname
DATABASE_URL=

# Logging level
LOG_LEVEL=INFO
