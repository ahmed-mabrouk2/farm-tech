# Django Settings
SECRET_KEY=your-very-long-random-secret-key-here-change-in-production
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,backend,frontend,nginx,0.0.0.0

# Database (Docker PostgreSQL)
DB_NAME=farm_db
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_HOST=db
DB_PORT=5432

# Redis (Docker Redis)
REDIS_URL=redis://redis:6379/0

# CORS - Update with your domains
CORS_ALLOWED_ORIGINS=http://localhost,http://localhost:3000,http://localhost:80,http://127.0.0.1,http://127.0.0.1:3000,http://127.0.0.1:80,http://backend:8000,http://frontend:3000,http://nginx:80

# Frontend API Configuration
NEXT_PUBLIC_API_URL=http://localhost:8000
API_BASE_URL=http://backend:8000

# Logging & Timezone
LOG_LEVEL=INFO
TZ=UTC
